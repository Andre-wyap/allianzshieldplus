  footer p { font-size: 0.78rem; color: rgba(255,255,255,0.4); line-height: 1.7; max-width: 600px; margin: 0 auto; }

  /* Toast */
  .toast { display: none; position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%); background: var(--green); color: white; padding: 14px 28px; border-radius: 50px; font-weight: 600; font-size: 0.9rem; z-index: 999; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
