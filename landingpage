  .btn-submit:hover { opacity: 0.9; }
  .selected-plan-info { background: linear-gradient(135deg,#003781,#006A86); color: white; border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
