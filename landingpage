    cursor: pointer; text-align: center; transition: all 0.2s; font-family: 'Montserrat', sans-serif;
  }
  .plan-card.selected .btn-view-full { background: var(--navy); color: white; border-color: var(--navy); }
  .plan-card .btn-view-full:hover { background: var(--navy); color: white; border-color: var(--navy); }

  /* MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(13,27,42,0.65); backdrop-filter: blur(4px);
