  .btn-add-nominee:hover { background: #EAF6FA; }
  .section-divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }
  .form-section-title { font-family: 'Montserrat', sans-serif; font-size: 0.85rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px; margin-top: 4px; }
  .btn-submit {
    width: 100%; padding: 16px; border-radius: 12px;
    background: linear-gradient(135deg, var(--navy), var(--teal));
    color: white; font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 700;
