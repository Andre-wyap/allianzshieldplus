  .benefits-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 24px; }
  @media(max-width:500px) { .benefits-grid { grid-template-columns: 1fr; } }
  .benefit-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; background: var(--light); border-radius: 10px; font-size: 0.82rem; }
  .benefit-row .b-label { color: var(--muted); }
  .benefit-row .b-val { font-weight: 600; color: var(--navy); text-align: right; max-width: 140px; }
