  .plan-card:hover { border-color: var(--sky); box-shadow: 0 4px 20px rgba(0,180,216,0.15); }
  .plan-card.selected { border-color: var(--navy); box-shadow: 0 4px 24px rgba(0,55,129,0.18); }
  .plan-card .plan-name { font-family: 'Montserrat', sans-serif; font-size: 0.8rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
  .plan-card .plan-sum { font-family: 'Montserrat', sans-serif; font-size: 1.4rem; font-weight: 800; color: var(--navy); line-height: 1; }
  .plan-card .plan-sum-label { font-size: 0.72rem; color: var(--muted); margin-top: 3px; margin-bottom: 14px; }
  .plan-card .plan-detail { font-size: 0.78rem; color: var(--muted); display: flex; justify-content: space-between; margin-bottom: 6px; }
  .plan-card .plan-detail strong { color: var(--dark); }
  .plan-card .plan-price { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border); }
  .plan-card .plan-price .price { font-family: 'Montserrat', sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--navy); }
  .plan-card .plan-price .price-label { font-size: 0.72rem; color: var(--muted); }
  .plan-card .selected-badge {
