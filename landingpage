  .faq-item.open .faq-q .arrow { transform: rotate(180deg); }
  .faq-a { display: none; padding: 0 20px 18px; font-size: 0.875rem; color: var(--muted); line-height: 1.7; background: white; }
  .faq-item.open .faq-a { display: block; }

  /* FOOTER */
  footer { background: var(--dark); padding: 40px 48px; text-align: center; }
