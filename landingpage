<script>
// ─── DATA ───────────────────────────────────────────────
const PLANS_A = [
  { name:'Plan 1', sum:60000, medical:3500, altMed:350, hospIncome:85, premium:{below50:103, above51:123} },
  { name:'Plan 2', sum:120000, medical:4500, altMed:400, hospIncome:85, premium:{below50:177, above51:212} },
  { name:'Plan 3', sum:180000, medical:5500, altMed:450, hospIncome:85, premium:{below50:229, above51:275} },
  { name:'Plan 4', sum:240000, medical:6500, altMed:500, hospIncome:110, premium:{below50:303, above51:363} },
  { name:'Plan 5', sum:360000, medical:7500, altMed:550, hospIncome:110, premium:{below50:418, above51:501} },
  { name:'Plan 6', sum:600000, medical:8500, altMed:600, hospIncome:185, premium:{below50:670, above51:804} },
  { name:'Plan 7', sum:900000, medical:9500, altMed:650, hospIncome:185, premium:{below50:943, above51:1131} },
  { name:'Plan 8', sum:1200000, medical:10000, altMed:700, hospIncome:235, premium:{below50:1248, above51:1497} },
  { name:'Plan 9', sum:2000000, medical:12000, altMed:750, hospIncome:250, premium:{below50:1816, above51:2179} },
  { name:'Plan 10', sum:3000000, medical:15000, altMed:800, hospIncome:300, premium:{below50:2674, above51:3209} },
];
const PLANS_B = [
  { name:'Plan 1', sum:60000, medical:3500, altMed:350, hospIncome:85, premium:{below50:168, above51:201} },
  { name:'Plan 2', sum:120000, medical:4500, altMed:400, hospIncome:85, premium:{below50:273, above51:327} },
  { name:'Plan 3', sum:180000, medical:5500, altMed:450, hospIncome:85, premium:{below50:389, above51:467} },
  { name:'Plan 4', sum:240000, medical:6500, altMed:500, hospIncome:110, premium:{below50:525, above51:630} },
  { name:'Plan 5', sum:360000, medical:7500, altMed:550, hospIncome:110, premium:{below50:788, above51:945} },
];

const FIXED_BENEFITS = [
  ['Blood Transfusion','20% of Principal Sum'],
  ['Dental/Cosmetic Surgery','Up to RM5,000'],
  ['Renewal Bonus','Up to 100% of Principal Sum'],
  ['Permanent Impotency/Infertility','20% of Principal Sum'],
  ['Kidnap — Expenses','RM10,000'],
  ['Kidnap — Reward','RM50,000'],
  ['Ambulance Fee','Up to RM500'],
  ['Funeral Expenses','RM5,000'],
  ['Bereavement Allowance','20% of Principal Sum'],
  ['Personal Liability','3× Principal Sum'],
  ['Mobility Expenses','Up to RM2,000'],
  ['Repatriation Expenses','Up to RM20,000'],
  ['Miscarriage (due to accident)','RM2,000'],
  ['Compassionate Care','Up to RM10,000'],
  ['Snatch Theft','RM600'],
  ['Double Indemnity (overseas/public transport)','2× Principal Sum + Renewal Bonus'],
];

let selectedAge = 'below50';
let selectedOcc = 'A';
let selectedPlanIndex = 0;

function fmt(n) { return 'RM ' + n.toLocaleString(); }

function renderPlans() {
  const plans = selectedOcc === 'A' ? PLANS_A : PLANS_B;
  const container = document.getElementById('plansContainer');
  container.innerHTML = '';
  plans.forEach((p, i) => {
    const price = p.premium[selectedAge];
    const card = document.createElement('div');
    card.className = 'plan-card' + (i === selectedPlanIndex ? ' selected' : '');
    card.innerHTML = `
      <span class="selected-badge">Selected</span>
      <div class="plan-name">${p.name}</div>
      <div class="plan-sum">${fmt(p.sum)}</div>
      <div class="plan-sum-label">Principal Sum Insured</div>
      <div class="plan-detail"><span>Medical Expenses</span><strong>${fmt(p.medical)}</strong></div>
      <div class="plan-detail"><span>Hospital Income/day</span><strong>RM ${p.hospIncome}</strong></div>
      <div class="plan-price">
        <div class="price">RM ${price.toLocaleString()}</div>
        <div class="price-label">per year (excl. 8% SST + RM10 stamp duty)</div>
      </div>
      <button class="btn-view-full" onclick="openPlanModal(${i})">View Full Benefits</button>
    `;
    card.addEventListener('click', (e) => {
      if (e.target.classList.contains('btn-view-full')) return;
      selectedPlanIndex = i;
      renderPlans();
    });
    container.appendChild(card);
  });
}

function setAge(val, btn) {
  selectedAge = val;
  btn.parentElement.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  selectedPlanIndex = 0;
  renderPlans();
}

function setOccupation(val, btn) {
  selectedOcc = val;
  btn.parentElement.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  selectedPlanIndex = 0;
  renderPlans();
}

function openPlanModal(idx) {
  selectedPlanIndex = idx;
  const plans = selectedOcc === 'A' ? PLANS_A : PLANS_B;
  const p = plans[idx];
  const price = p.premium[selectedAge];
  const ageLabel = selectedAge === 'below50' ? 'Age 50 & below' : 'Age 51–80';
  const occLabel = selectedOcc === 'A' ? 'Occupation Category A (Office)' : 'Occupation Category B (Manual)';

  document.getElementById('modalPlanName').textContent = `Allianz Shield Plus — ${p.name}`;
  document.getElementById('modalPlanSub').textContent = `${occLabel} · ${ageLabel} · RM ${price.toLocaleString()}/year`;

  const dynamicBenefits = [
    ['Principal Sum (Accidental Death/Disablement)', fmt(p.sum)],
    ['Medical Expenses', fmt(p.medical)],
    ['Alternative Medicine', fmt(p.altMed)],
    ['Hospital Income (max 180 days)', `RM ${p.hospIncome}/day`],
  ];
  const allBenefits = [...dynamicBenefits, ...FIXED_BENEFITS];
  const grid = document.getElementById('modalBenefits');
  grid.innerHTML = allBenefits.map(([label, val]) => `
    <div class="benefit-row">
      <span class="b-label">${label}</span>
      <span class="b-val">${val}</span>
    </div>
  `).join('');

  document.getElementById('planModal').classList.add('open');
  renderPlans();
}

function closePlanModal() {
  document.getElementById('planModal').classList.remove('open');
}

// ─── DOCUMENT POPUPS ─────────────────────────────────────
function openDoc(type) {
  const urls = {
    pds: 'https://www.allianz.com.my/content/dam/onemarketing/azmb/wwwallianzcommy/product-document/ASP-PDS_ENG.pdf',
    wording: 'https://www.allianz.com.my/content/dam/onemarketing/azmb/wwwallianzcommy/personal/life-health-and-savings/personal-accident/allianz-shield-plus/AllianzShieldPlus_PW_EN.pdf',
    brochure: 'https://www.allianz.com.my/content/dam/onemarketing/azmb/wwwallianzcommy/product-document/ASP_newBrochure_ENG.pdf',
  };
  const url = urls[type];
  if (url.startsWith('PLACEHOLDER')) {
    alert('Document link coming soon. Please contact your FINNO advisor for the document.');
    return;
  }
  window.open(url, '_blank', 'noopener,noreferrer');
}

// ─── APPLICATION FORM ─────────────────────────────────────
let nomineeCount = 0;

function openAppModal() {
  const plans = selectedOcc === 'A' ? PLANS_A : PLANS_B;
  const p = plans[selectedPlanIndex];
  const price = p.premium[selectedAge];
  const occLabel = selectedOcc === 'A' ? 'Category A (Office)' : 'Category B (Manual)';
  document.getElementById('appPlanName').textContent = `${p.name} · ${occLabel}`;
  document.getElementById('appPlanPrice').textContent = `RM ${price.toLocaleString()}/year`;
  document.getElementById('appModal').classList.add('open');
  closePlanModal();
}

function closeAppModal() {
  document.getElementById('appModal').classList.remove('open');
}

function addNominee() {
  if (nomineeCount >= 2) { alert('Maximum 2 nominees allowed.'); return; }
  nomineeCount++;
  const container = document.getElementById('nomineeContainer');
  const block = document.createElement('div');
  block.className = 'nominee-block';
  block.id = `nominee-${nomineeCount}`;
  block.innerHTML = `
    <h5>Nominee ${nomineeCount}</h5>
    <button class="btn-remove-nominee" onclick="removeNominee(${nomineeCount})">✕ Remove</button>
    <div class="form-row">
      <div class="form-field"><label>Full Name</label><input type="text" id="n${nomineeCount}_name" placeholder="Full name"></div>
      <div class="form-field"><label>NRIC Number</label><input type="text" id="n${nomineeCount}_nric" placeholder="e.g. 901231-01-1234"></div>
    </div>
    <div class="form-row">
      <div class="form-field"><label>Relationship</label>
        <select id="n${nomineeCount}_rel">
          <option value="">Select relationship</option>
          <option>Spouse</option><option>Child</option><option>Parent</option>
          <option>Sibling</option><option>Other</option>
        </select>
      </div>
      <div class="form-field"><label>Share %</label><input type="number" id="n${nomineeCount}_share" placeholder="e.g. 50" min="1" max="100"></div>
    </div>
  `;
  container.appendChild(block);
  if (nomineeCount >= 2) document.getElementById('addNomineeBtn').style.display = 'none';
}

function removeNominee(id) {
  const el = document.getElementById(`nominee-${id}`);
  if (el) { el.remove(); nomineeCount--; }
  document.getElementById('addNomineeBtn').style.display = 'inline-flex';
}

function submitApplication() {
  const name = document.getElementById('f_name').value.trim();
  const nric = document.getElementById('f_nric').value.trim();
  const email = document.getElementById('f_email').value.trim();
  const phone = document.getElementById('f_phone').value.trim();
  if (!name || !nric || !email || !phone) { alert('Please fill in all required fields.'); return; }

  const plans = selectedOcc === 'A' ? PLANS_A : PLANS_B;
  const p = plans[selectedPlanIndex];
  const price = p.premium[selectedAge];

  const nominees = [];
  for (let i = 1; i <= 2; i++) {
    const nEl = document.getElementById(`nominee-${i}`);
    if (nEl) {
      nominees.push({
        name: document.getElementById(`n${i}_name`)?.value || '',
        nric: document.getElementById(`n${i}_nric`)?.value || '',
        relationship: document.getElementById(`n${i}_rel`)?.value || '',
        share: document.getElementById(`n${i}_share`)?.value || '',
      });
    }
  }

  const payload = {
    plan: p.name,
    occupation_category: selectedOcc,
    age_group: selectedAge,
    annual_premium: price,
    sum_insured: p.sum,
    personal: {
      name: name,
      nric: nric,
      dob: document.getElementById('f_dob').value,
      address: document.getElementById('f_address').value,
      email: email,
      phone: phone,
      occupation: document.getElementById('f_occupation').value,
    },
    nominees: nominees,
    submitted_at: new Date().toISOString(),
  };

  const WEBHOOK_URL = 'https://n8n.srv1120581.hstgr.cloud/webhook-test/cbd17f88-64c0-403c-a626-9446f30cf123'; // ← Replace with your n8n webhook URL
  const REDIRECT_URL = 'https://finnomalaysia.com/thank-you/'; // ← Replace with your post-submission redirect URL

  const handleSuccess = () => {
    closeAppModal();
    if (REDIRECT_URL !== 'https://finnomalaysia.com/thank-you/') {
      window.location.href = REDIRECT_URL;
    } else {
      showToast();
    }
  };

  if (WEBHOOK_URL === 'https://n8n.srv1120581.hstgr.cloud/webhook-test/cbd17f88-64c0-403c-a626-9446f30cf123') {
    console.log('Webhook payload:', payload);
    handleSuccess();
    return;
  }

  fetch(WEBHOOK_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  })
  .then(() => handleSuccess())
  .catch(() => handleSuccess());
}

function showToast() {
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 4000);
}

// ─── FAQ ──────────────────────────────────────────────────
function toggleFaq(el) {
  const item = el.parentElement;
  item.classList.toggle('open');
}

// ─── CLOSE MODALS ON OVERLAY CLICK ───────────────────────
document.getElementById('planModal').addEventListener('click', function(e) {
  if (e.target === this) closePlanModal();
});
document.getElementById('appModal').addEventListener('click', function(e) {
  if (e.target === this) closeAppModal();
});

// ─── INIT ─────────────────────────────────────────────────
renderPlans();
</script>
